<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.project.commerce.user.mapper.UserMapper">

    <insert id="insertUser">
        INSERT INTO users (email, password, name)
        VALUES (#{email}, #{password}, #{name})
    </insert>

    <select id="findAll" resultType="com.project.commerce.user.entity.User">
        SELECT * FROM users
    </select>

    <select id="findById" resultType="com.project.commerce.user.entity.User">
        SELECT * FROM users WHERE id = #{id}
    </select>

    <select id="findByEmail" resultType="com.project.commerce.user.entity.User">
        SELECT * FROM users WHERE email = #{email}
    </select>

    <update id="updateUser">
        UPDATE users
        SET email = #{email},
        password = #{password},
        name = #{name}
        WHERE id = #{id}
    </update>

    <delete id="deleteUser">
        DELETE FROM users WHERE id = #{id}
    </delete>

</mapper>